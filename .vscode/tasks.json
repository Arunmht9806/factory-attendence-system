{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "composer-install-laravel",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Set-Location laravel_app; php ..\\composer.phar install"
			],
			"isBackground": false
		},
		{
			"label": "php-lint-laravel-bridge",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
